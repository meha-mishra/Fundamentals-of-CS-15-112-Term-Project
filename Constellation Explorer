def drawFindConstellation(app): 
    drawSetup(app)
    
    #restricted vision
    if app.difficulty == 'hard': 
        drawVisionMask(app)
    
    #handle start/reset game
    if not app.gameInProgress: 
        if not(app.gameOver or app.youWon): 
            (app.Start).draw()
        else: 
            (app.Reset).draw()
    else: 
        (app.Reset).draw()
   
    if app.gameInProgress and not(app.gameOver or app.youWon): 
        color = 'white' if float(app.timer) > 10 else 'red'
        drawLabel(app.timer, 160, 40, align='center', size=25, font='montserrat', fill=color, bold=True)
    
    playGame(app)
        

def playGame(app):
    i = findCurrentSlide(app)
    #prompt
    if app.gameInProgress: 
        drawLabel(f'Find {app.currentConstellation}', 120, 80, size=20, fill='white', align='center', 
                    font = 'montserrat', bold=True)
    
    #draw found constellations
    for constellation in app.clickedConstellations: 
        if constellation in app.constellations[i] and app.gameInProgress: 
            url, cx, cy, sizeFactor, angle = app.constellationInfo[constellation]
            imageWidth, imageHeight = getImageSize(url)
            drawImage(url, cx, cy, width=sizeFactor*imageWidth, height=sizeFactor*imageHeight, 
                      align='center', rotateAngle = angle)
   
    #handle incorrect click
    if app.errorMessage: 
        drawRect(app.width//2, app.height//2, app.width, 40, fill='white', opacity = 40, align='center')
        drawLabel(f'Not quite! This constellation is: {app.pickedConstellation}', app.width//2, app.height//2, size = 20, fill='pink', bold=True, font='montserrat')
    
    #draw hearts/lives
    if app.difficulty != 'easy':
        heart = 'cmu://1166316/46637434/471da8fa-7c7f-47ac-8ad8-1e8cc7ef787f.png'
        for i in range(app.lives): 
            imageWidth, imageHeight = getImageSize(heart)
            drawImage(heart, 20, 20 + 40*i, width=0.15*imageWidth, height=0.15*imageHeight, align='center')
    
    
    if app.youWon: 
        drawLabel('You won!', app.width//2, app.height//2, size = 48, fill='green', bold=True, font='montserrat')
    elif app.gameOver: 
        drawLabel('Game Over!', app.width//2, app.height//2, size = 48, fill='red', bold=True, font='montserrat')

def drawVisionMask(app): 
    cx, cy, r = app.mouseX, app.mouseY, 100
    telescope = 'cmu://1166316/46649583/unnamed.png'
    imageWidth, imageHeight = getImageSize(telescope)
    if (cx, cy) == (None, None): 
        return
    if r < cy:
        drawRect(0, 0, app.width, cy - r, fill='grey', opacity = 90)
    if (cy + r) < app.height: 
        drawRect(0, cy + r, app.width, app.height - (cy + r), fill='grey', opacity = 90)
    if r < cx:
        drawRect(0, cy - r, cx - r, 2*r, fill='grey', opacity = 90)
    if (cx + r) < app.width:
        drawRect(cx + r, cy - r, app.width - (cx + r), 2*r, fill='grey', opacity = 90)
    drawImage(telescope, cx, cy, align='center', width=0.2*imageWidth, height=0.2*imageHeight)



