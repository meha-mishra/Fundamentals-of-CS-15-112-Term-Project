def getTimeType(app): 
    if app.difficulty == 'easy': 
        return app.easyTime
    elif app.difficulty == 'intermediate': 
        return app.medTime
    else: 
        return app.hardTime
        
def findCurrentSlide(app): 
    for i in range(len(app.slides)): 
        if app.slides[i]: 
            return i
    return 4 #top slide, index doesn't exist in app.slides but does in app.images
    
def inButton(app, mouseX, mouseY, i): 
    if app.specialButtons[i] == 'left': 
        return (distance(mouseX, mouseY, 40, app.height//2) < 40)
    elif app.specialButtons[i] == 'up': 
        return (distance(mouseX, mouseY, app.width//2, 40) < 40)
    elif app.specialButtons[i] == 'right': 
        return (distance(mouseX, mouseY, app.width - 40, app.height//2) < 40)
    elif app.specialButtons[i] == 'down': 
        return (distance(mouseX, mouseY, app.width//2, app.height-40) < 40)
    elif app.specialButtons[i] == 'instructions': 
        return (40 <= mouseX <= 120 and 30 <= mouseY <= 50)
    
def distance(x1, y1, x2, y2):
    a = x2 - x1
    b = y2 - y1
    c = float (math.sqrt(a**2 + b**2))
    return abs(c)
        

