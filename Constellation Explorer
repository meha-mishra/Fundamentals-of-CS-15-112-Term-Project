def onKeyPress(app, key):
    if key == 'p': 
        app.gameInProgress = not app.gameInProgress
    if key == 'w': 
        app.gameInProgress, app.youWon = False, True
    if key == 'l': 
        app.gameInProgress, app.gameOver = False, True
    pass

def onMouseMove(app, mouseX, mouseY): 
    #for vision mask    
    app.mouseX, app.mouseY = mouseX, mouseY
    
    #check if mouse in special buttons
    for i in range(len(app.specialButtons)): #excluding exit instructions, switch mode, startGame
        if inButton(app, mouseX, mouseY, i):
            #full opacity
            app.buttonOpacities[i] = 80
        else: 
            #low opacity
            app.buttonOpacities[i] = 20
            
    #check if mouse in Constellation
    i = findCurrentSlide(app)
    app.showConstellation = inConstellation(app, mouseX, mouseY, i)


def onStep(app):
    #timer 
    timer = float(app.timer)
    if app.gameInProgress:
        timer -= 0.1
        #the following line was taken from chatGPT
        app.timer = f'{timer: 0.1f}'
    
    #error message timeout    
    if app.errorMessage: 
        app.errorTime += 1
        if app.errorTime == 20:
            app.errorTime = 0
            app.errorMessage = False
    
    #handle running out of time
    if app.timer == '0.0' and (len(app.clickedConstellations) != len(app.constellationInfo)): 
        app.gameInProgress, app.gameOver = False, True
        app.timer = getTimeType(app)

def onMousePress(app, mouseX, mouseY):
    #click anywhere to get rid of error message
    app.errorMessage = False
    
    i = findCurrentSlide(app)
    handleSlideNavigation(app, mouseX, mouseY, i)
    
    #open instructions
    if (inButton(app, mouseX, mouseY, 4) and 
        not app.showInstructions): 
        app.showInstructions = True
     
    #start/reset buttons 
    if not app.gameInProgress: 
        if not(app.gameOver or app.youWon): 
            (app.Start).handleClick(mouseX, mouseY)
        else: 
            (app.Reset).handleClick(mouseX, mouseY)
    else: 
        (app.Reset).handleClick(mouseX, mouseY)
    #other buttons
    for button in app.buttons: 
        button.handleClick(mouseX, mouseY)
    
    #constellation interaction
    if app.showConstellation != None: 
        app.pickedConstellation = app.showConstellation
        app.showDescription = True
        if app.gameInProgress:
            if app.currentConstellation == app.pickedConstellation:
                handleCorrectClick(app)
            else:
                handleIncorrectClick(app)
    #exit constellation info (click outside description)
    elif app.showConstellation == None: 
        app.showDescription = False


