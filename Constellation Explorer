def handleSlideNavigation(app, mouseX, mouseY, i): 
    if app.slideTop == False: 
        if inButton(app, mouseX, mouseY, 0): #left
            app.slides[i] = False
            j = i - 1
            app.slides[j] = True 
            print('left', j, i)
        if inButton(app, mouseX, mouseY, 1): #up
            app.prevSlide = i
            app.slides[i] = False
            app.slideTop = True 
            print('up')
        if inButton(app, mouseX, mouseY, 2): #right
            app.slides[i] = False
            j = (i + 1) % 4
            app.slides[j] = True 
    elif inButton(app, mouseX, mouseY, 3): #down
        app.slides[app.prevSlide] = True
        app.slideTop = False # top slide False

def handleCorrectClick(app): 
    app.clickedConstellations += [app.currentConstellation]
    if len(app.clickedConstellations) == len(app.constellationInfo): 
        app.gameInProgress, app.youWon = False, True
        app.timer = getTimeType(app)
    else: 
        pickNewConstellation(app)

def handleIncorrectClick(app): 
    app.errorMessage = True
    if app.difficulty != 'easy': 
        app.lives -= 1
        if app.lives == 0: 
            app.gameInProgress, app.gameOver = False, True
            
def pickNewConstellation(app): 
    while app.currentConstellation in app.clickedConstellations: 
        app.currentConstellation = random.choice(list(app.descriptions))
           
def inConstellation(app, mouseX, mouseY, slide): 
    potentialConstellations = app.constellations[slide]
    for constellation in potentialConstellations: 
        xMin, xMax, yMin, yMax = app.constellationLocations[constellation]
        if xMin <= mouseX <= xMax and yMin <= mouseY <= yMax: 
            return constellation
    return None

#the following class was taken from lauren's lecture           
class Button: 
    def __init__(self, left, top, width, height, color, text, textSize, onClickFn, opacity=100,): 
        self.left = left
        self.top = top
        self.width = width
        self.height = height
        self.color = color
        self.text = text
        self.textSize = textSize
        self.onClickFn = onClickFn
        self.opacity = opacity
    
    def handleClick(self, mouseX, mouseY): 
        if ((self.left <= mouseX <= (self.left + self.width)) and 
        (self.top <= mouseY <= (self.top + self.height))): 
            self.onClickFn()
    
    def draw(self): 
        drawRect(self.left, self.top, self.width, self.height, fill=self.color, opacity = self.opacity)
        cx, cy = self.left + self.width/2, self.top + self.height/2
        drawLabel(self.text, cx, cy, size= self.textSize, bold=True, font='montserrat')
 
